# Restic repository (S3-compatible)
# Examples:
#   s3:https://s3.amazonaws.com/your-bucket/lyth-backups
#   s3:https://your-minio.example.com/lyth-backups
#   /mnt/backups/lyth (local path)
RESTIC_REPOSITORY=

# Restic encryption password (used to encrypt/decrypt all backups)
RESTIC_PASSWORD=

# S3 credentials (not needed for local repository)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

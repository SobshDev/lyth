{
  "uid": "logs",
  "title": "Logs",
  "description": "Container logs collected via Alloy and stored in Loki",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "editable": false,
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "type": 1, "label": "service_name", "stream": "" },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "current": { "text": "", "value": "" }
      },
      {
        "name": "level",
        "label": "Level",
        "type": "custom",
        "query": "All : ,Error : error|fatal|panic|exception,Warn : warn|warning,Info : info,Debug : debug",
        "current": { "text": "All", "value": "" },
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Log Volume",
      "type": "barchart",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name) (count_over_time({service_name=~\"$service\"} |~ \"(?i)$search\" [$__auto]))",
          "legendFormat": "{{ service_name }}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Error Count",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name) (count_over_time({service_name=~\"$service\"} |~ \"(?i)$search\" |~ \"(?i)(error|err|panic|fatal|exception)\" [$__auto]))",
          "legendFormat": "{{ service_name }}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 0,
            "fillOpacity": 60,
            "stacking": { "mode": "normal" },
            "showPoints": "never"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Logs",
      "type": "logs",
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=~\"$service\"} |~ \"(?i)$search\" |~ \"(?i)$level\"",
          "maxLines": 500
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ]
}

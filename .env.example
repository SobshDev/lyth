# Grafana Admin
GF_SECURITY_ADMIN_USER=
GF_SECURITY_ADMIN_PASSWORD=

# Grafana SMTP (optional — set GF_SMTP_ENABLED=true only when all SMTP fields below are populated)
GF_SMTP_ENABLED=false
# SMTP server host:port (e.g. smtp.gmail.com:587)
GF_SMTP_HOST=
GF_SMTP_USER=
GF_SMTP_PASSWORD=
# Sender email address (e.g. alerts@yourdomain.com)
GF_SMTP_FROM_ADDRESS=
GF_SMTP_FROM_NAME=Lyth Monitoring
